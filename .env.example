# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=bluebot
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
POSTGRES_DB=bluebot
DATABASE_URL=postgresql+asyncpg://bluebot:CHANGE_ME_URL_ENCODED_PASSWORD@postgres:5432/bluebot

# ── API Security ─────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_GENERATE_WITH_PYTHON_SECRETS_TOKEN_HEX_32

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_GENERATE_WITH_FERNET_GENERATE_KEY
BLUEBOT_FERNET_KEY=CHANGE_ME_GENERATE_WITH_FERNET_GENERATE_KEY
INSTALL_TOKEN=CHANGE_ME_GENERATE_WITH_PYTHON_SECRETS_TOKEN_URLSAFE_32

# Admin panel credentials (hashed password stored in DB on first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ── API Host ──────────────────────────────────────────────────
# Public URL of this API (used by executables to reach the license server)
API_BASE_URL=https://api.bluebot.com

# ── CORS Configuration ─────────────────────────────────────────
# Comma-separated list of allowed origins for cross-origin requests
# Leave empty to use defaults: http://localhost:8080, https://admin.bluebotapp.com.br
# Example: https://admin.bluebotapp.com.br,https://example.com
CORS_ALLOWED_ORIGINS=

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── App Version ───────────────────────────────────────────────
APP_VERSION=1.0.0

# Offer filter (local bot)
OFFER_FILTER_ENABLED=true
OFFER_FILTER_MAX_POSTS_PER_DAY=10
OFFER_FILTER_MAX_PER_CATEGORY_DAY=3
OFFER_FILTER_MIN_SCORE=40
OFFER_FILTER_MIN_DISCOUNT_PCT=30
OFFER_FILTER_MIN_PRICE=15
OFFER_FILTER_MAX_PRICE=500
OFFER_FILTER_DB_PATH=data/offer_filter.sqlite3

# ── Amazon Affiliate ──────────────────────────────────────────
CONV_AMZ=false
AMZ_COOKIES=

# ── Environment ───────────────────────────────────────────────
# "production" = Swagger/docs desabilitado (seguro)
# "development" = Swagger/docs habilitado em /docs
ENVIRONMENT=production

# ── Security ───────────────────────────────────────────────────
# WARNING: Never commit actual .env with production credentials to version control
# Use Docker secrets or environment-specific configuration in production

