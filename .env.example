# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=bluebot
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=bluebot

# ── API Security ─────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_jwt_secret_at_least_32_chars_long

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change_me_fernet_key_generated_by_cryptography

# Admin panel credentials (hashed password stored in DB on first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password

# ── API Host ──────────────────────────────────────────────────
# Public URL of this API (used by executables to reach the license server)
API_BASE_URL=https://api.yourdomain.com

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── App Version ───────────────────────────────────────────────
APP_VERSION=1.0.0
