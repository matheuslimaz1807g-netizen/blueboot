# ── Telegram ──────────────────────────────────────────────────────────────────
API_ID=SEU_API_ID_AQUI
API_HASH=SEU_API_HASH_AQUI
TELEGRAM_PHONE=+55119XXXXXXXX

# Session string gerada na primeira autenticação (deixe em branco na 1ª vez)
TELEGRAM_SESSION_STRING=

# Grupos/canais para monitorar (username sem @, separados por vírgula)
SOURCE=canal_promos,outro_canal

# Grupo/canal de destino no Telegram
DESTINATION=meu_grupo_destino

# ── WhatsApp ──────────────────────────────────────────────────────────────────
ENABLE_WHATSAPP=false
WHATSAPP_DESTINATIONS=Meu Grupo WhatsApp
WHATSAPP_ENDPOINT=http://whatsapp:4000/send

# ── Configurações gerais ───────────────────────────────────────────────────────
ENABLE_TELEGRAM=true
DELAY=3

# ── Conversão de afiliados ─────────────────────────────────────────────────────
CONV_SHOPEE=true
CONV_ALI=true
CONV_ML=true

SHOPEE_TOKEN=
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
ALIEXPRESS_TRACKING_ID=
ML_TOKEN=
