{
    email mathe@hostinger.com
}

# Usando apenas a porta 80 (HTTP) para garantir acesso via IP ou Domínio
:80 {
    # Redireciona a raiz para o admin
    redir / /admin/ 301

    # Proxy para a API
    handle /license/* {
        reverse_proxy license_api:8000
    }
    handle /config/* {
        reverse_proxy license_api:8000
    }
    handle /version/* {
        reverse_proxy license_api:8000
    }

    # Rotas da API Administrativa
    handle /admin/login {
        reverse_proxy license_api:8000
    }
    handle /admin/licenses* {
        reverse_proxy license_api:8000
    }
    handle /admin/pending* {
        reverse_proxy license_api:8000
    }
    handle /admin/link* {
        reverse_proxy license_api:8000
    }

    # Painel Admin (Arquivos Estáticos)
    handle /admin* {
        root * /usr/share/caddy/admin
        file_server browse
        try_files {path} {path}/ /admin/index.html
    }

    encode zstd gzip
}
