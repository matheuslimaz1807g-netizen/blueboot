srv1630892.hstgr.cloud {
    # Redireciona a raiz para o admin
    redir / /admin/ 301

    # 1. Tudo que for /license, /config ou /version vai direto para a API
    handle /license/* {
        reverse_proxy license_api:8000
    }
    handle /config/* {
        reverse_proxy license_api:8000
    }
    handle /version/* {
        reverse_proxy license_api:8000
    }

    # 2. Rotas específicas da API Admin (Login, Licenses, etc)
    # IMPORTANTE: Colocamos antes dos arquivos estáticos
    handle /admin/login {
        reverse_proxy license_api:8000
    }
    handle /admin/licenses* {
        reverse_proxy license_api:8000
    }
    handle /admin/pending* {
        reverse_proxy license_api:8000
    }
    handle /admin/link* {
        reverse_proxy license_api:8000
    }
    handle /admin/logs* {
        reverse_proxy license_api:8000
    }

    # 3. Todo o resto em /admin serve os arquivos HTML/JS
    handle /admin* {
        root * /usr/share/caddy/admin
        file_server browse
        try_files {path} {path}/ /admin/index.html
    }

    # Segurança
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
    }

    encode zstd gzip
}
