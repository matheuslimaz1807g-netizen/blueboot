# =============================================================================
# BlueBot — clientes/template/.env.example
# Copie para clientes/<slug>/.env e preencha todos os valores.
# NUNCA faça commit do .env real no Git.
# =============================================================================

# -----------------------------------------------------------------------------
# Identificação do cliente
# -----------------------------------------------------------------------------

# Slug único do cliente (letras minúsculas, números e hífens, sem espaços).
# Exemplo: empresa-abc, joao-silva, loja-xyz
# Usado para nomear containers, volumes e rota de acesso.
CLIENTE_SLUG=

# -----------------------------------------------------------------------------
# Autenticação na API Central
# -----------------------------------------------------------------------------

# Chave de licença do cliente no formato APRO-XXXX-XXXX-XXXX.
# Obtida no painel admin após criar a licença.
LICENSE_KEY=

# Senha definida para este cliente no painel admin.
# Usada pelo bot para autenticar na API central.
CLIENT_PASSWORD=

# URL da API Central.
# Em produção via rede Docker interna (sem passar pela internet):
#   http://api:8000
# Em desenvolvimento local:
#   http://localhost:8000
APRO_API_BASE=http://api:8000

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------

# ID da aplicação Telegram obtido em https://my.telegram.org
# Necessário para o Pyrogram/Telethon conectar à conta do cliente.
TELEGRAM_API_ID=

# Hash da aplicação Telegram obtido em https://my.telegram.org
TELEGRAM_API_HASH=

# Número de telefone da conta Telegram do cliente (formato internacional).
# Exemplo: +5511999999999
TELEGRAM_PHONE=

# String de sessão gerada pelo bot após a primeira autenticação.
# Deixe vazio na primeira vez — o bot irá gerar e salvar automaticamente.
TELEGRAM_SESSION_STRING=

# -----------------------------------------------------------------------------
# WhatsApp
# -----------------------------------------------------------------------------

# Endpoint interno do container WhatsApp deste cliente.
# Preenchido automaticamente pelo script novo-cliente.sh.
# Formato: http://whatsapp_<slug>:4000
WHATSAPP_ENDPOINT=http://whatsapp_${CLIENTE_SLUG}:4000

# -----------------------------------------------------------------------------
# Afiliados (deixe vazio se o cliente não usar o serviço)
# -----------------------------------------------------------------------------

# Token da API Shopee Affiliates (se o cliente usar conversão Shopee)
SHOPEE_TOKEN=

# App Key da conta AliExpress Portals (se usar conversão AliExpress)
ALI_KEY=

# App Secret da conta AliExpress Portals
ALI_SECRET=

# Tracking ID AliExpress (Sub ID 1)
ALI_TRACKING=

# Token OAuth Mercado Livre Affiliates (se usar conversão ML)
ML_TOKEN=

# -----------------------------------------------------------------------------
# Configurações do bot
# -----------------------------------------------------------------------------

# Canal/grupo Telegram de origem das mensagens (pode ser username ou ID numérico)
# Múltiplos valores separados por vírgula: canal1,canal2
TELEGRAM_SOURCES=

# Destino Telegram onde o bot publica (username do canal/grupo ou ID)
TELEGRAM_DESTINATION=

# Delay entre mensagens em segundos (padrão: 3)
BOT_DELAY_SEGUNDOS=3

# Variável reconhecida pelo código Python para ajustar paths no container
DOCKER_CONTAINER=1
