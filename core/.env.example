# =============================================================================
# BlueBot — core/.env.example
# Copie este arquivo para .env e preencha todos os valores
#
# NUNCA faça commit do arquivo .env real no Git.
# Adicione .env ao seu .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

# Nome do usuário do banco de dados
POSTGRES_USER=bluebot

# Senha forte para o PostgreSQL.
# Gere com: openssl rand -base64 32
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI

# Nome do banco de dados
POSTGRES_DB=bluebot

# -----------------------------------------------------------------------------
# FastAPI / Alembic
# (DATABASE_URL é montada automaticamente pelo docker-compose a partir das
#  variáveis acima. Não precisa definir aqui.)
# -----------------------------------------------------------------------------

# Chave secreta para assinar JWTs de administradores.
# Gere com: openssl rand -hex 32
JWT_SECRET=TROQUE_POR_HEX_64_CHARS_AQUI

# Algoritmo JWT (não altere sem motivo)
JWT_ALGORITHM=HS256

# Expiração dos tokens de admin em minutos
JWT_EXPIRE_MINUTES=60

# Chave Fernet para criptografar credenciais dos clientes no banco.
# Gere com: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ATENÇÃO: se trocar esta chave, todos os dados criptografados ficam ilegíveis.
BLUEBOT_FERNET_KEY=TROQUE_POR_FERNET_KEY_BASE64_AQUI

# Token secreto usado pelo script de instalação do executável para
# registrar novas licenças. Gere com: openssl rand -base64 24
INSTALL_TOKEN=TROQUE_POR_TOKEN_INSTALACAO

# -----------------------------------------------------------------------------
# Credenciais do painel Admin
# -----------------------------------------------------------------------------

# Login do administrador principal do sistema
ADMIN_USERNAME=admin

# Senha do administrador. Use algo complexo.
# Gere com: openssl rand -base64 16
ADMIN_PASSWORD=TROQUE_POR_SENHA_ADMIN

# -----------------------------------------------------------------------------
# URLs e configurações da API
# -----------------------------------------------------------------------------

# URL pública da API (usada pelo executável dos clientes)
API_BASE_URL=https://api.bluebotapp.com.br

# Limite de requisições por minuto por IP
RATE_LIMIT_PER_MINUTE=60

# Backend do rate limiter. Use "memory://" para single-node.
# Para múltiplos workers, use Redis: "redis://redis:6379/0"
RATE_LIMIT_STORAGE_URL=memory://

# Versão atual do executável (exibida no painel e usada para update checker)
APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# COMO GERAR OS SECRETS (execute no terminal da VPS)
# -----------------------------------------------------------------------------
# JWT_SECRET:
#   openssl rand -hex 32
#
# BLUEBOT_FERNET_KEY:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# POSTGRES_PASSWORD:
#   openssl rand -base64 32
#
# INSTALL_TOKEN:
#   openssl rand -base64 24
#
# ADMIN_PASSWORD:
#   openssl rand -base64 16
# -----------------------------------------------------------------------------
