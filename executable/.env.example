# 🔒 BlueBot — MODO GERENCIADO (Licenciado)
# 
# ✅ NÃO PREENCHA LICENSE_KEY MANUALMENTE!
# O robô irá:
#   1. Se iniciar sem licença
#   2. Registrar-se automaticamente no Painel Admin
#   3. Aguardar sua aprovação no painel
#   4. Quando aprovado, a LICENSE_KEY é preenchida automaticamente
#
# Este arquivo é um exemplo de como configurar o robô.

# ── PAINEL DE ADMINISTRAÇÃO (Obrigatório) ──────────────────────────────────────
# URL do servidor de gestão (fornecido pelo seu provedor)
APRO_API_BASE=https://seu-painel.com

# Token de instalação (usado para registrar este robô no painel)
# Deixe em branco se o painel não exigir
INSTALL_TOKEN=

# Rótulo para este robô (opcional - aparece no painel)
ROBOT_LABEL=Bot - Máquina Principal

# ── TELEGRAM (Opcional) ────────────────────────────────────────────────────────
# Obtenha em: https://my.telegram.org/apps
API_ID=1234567
API_HASH=abcdef1234567890abcdef1234567890

# ── OBSERVAÇÃO IMPORTANTE ─────────────────────────────────────────────────────
# 
# ✅ TUDO É GERENCIADO PELO PAINEL ADMIN APÓS AUTORIZAÇÃO:
#   • Canais/Grupos Telegram
#   • Grupos WhatsApp
#   • Chaves de afiliados (Shopee, AliExpress, Mercado Livre)
#   • Status (Ativo/Parado)
#   • Delays e comportamentos
#
# ✅ LICENSE_KEY É PREENCHIDA AUTOMATICAMENTE:
#   1. Execute o robô: ./ApenasPromo.exe
#   2. Ele se registrará no painel
#   3. Vá ao Painel Admin → Máquinas
#   4. Localize esta máquina e clique em "AUTORIZAR"
#   5. LICENSE_KEY é preenchida automaticamente! ✨
#
# ❌ NUNCA edite manualmente as chaves de afiliados aqui
# 
# Para suporte: Acesse o Painel Admin ou contate o administrador

