# ── Client Config ────────────────────────────────────────────────────────────
LICENSE_KEY=SUA_CHAVE_AQUI
APRO_API_BASE=https://api.bluebotapp.com.br
CLIENT_SLUG=cliente

# ── Security ──────────────────────────────────────────────────────────────────
# Use a mesma FERNET_KEY do seu servidor principal para consistência
FERNET_KEY=SUA_FERNET_KEY_AQUI

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# IMPORTANTE: Altere 'whatsapp_matheus' pelo nome do container do cliente
WHATSAPP_ENDPOINT=http://whatsapp_matheus:4000/send

# ── Dashboard Auth ────────────────────────────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=admin123
